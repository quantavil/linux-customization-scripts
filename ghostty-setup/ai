#!/bin/sh
# Lightweight CLI assistant with conversation memory using Groq API, curl + jq.

# Dependency checks
for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { printf 'Error: %s is required but not installed.\n' "$cmd" >&2; exit 1; }
done

HISTORY_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/groq-cli"
CONFIG_FILE="$HISTORY_DIR/config.json"
HISTORY_FILE="$HISTORY_DIR/history.json"
DEFAULT_MODEL="qwen/qwen3.6-27b"
SEARCH_MODEL="${GROQ_SEARCH_MODEL:-compound-beta}"
API_BASE="https://api.groq.com/openai/v1"
CONTEXT_THRESHOLD=80000   # chars (~20K tokens)
EXPIRY_SECONDS=10800      # 3 hours
KEEP_RECENT=8             # messages to keep verbatim during summarization (4 exchanges)

# POSIX-compliant literal newline for splitting strings
nl='
'

HOLDS_LOCK=0   # FIX: track whether THIS instance owns the lock

# Concurrent run locking using lock directory
lock_history() {
    lock_dir="$HISTORY_FILE.lock"
    retry=0
    while ! mkdir "$lock_dir" 2>/dev/null; do
        if [ "$retry" -eq 10 ]; then                       # FIX: print once, not every loop
            printf 'Waiting for history lock...\n' >&2
        fi
        if [ "$retry" -ge 30 ]; then
            printf 'Failed to acquire history lock. Another instance of ai may be running.\n' >&2
            exit 1
        fi
        sleep 0.1
        retry=$((retry + 1))
    done
    HOLDS_LOCK=1                                            # FIX
}

unlock_history() {
    [ "$HOLDS_LOCK" -eq 1 ] || return 0                    # FIX: only release if we own it
    rmdir "$HISTORY_FILE.lock" 2>/dev/null
    HOLDS_LOCK=0                                            # FIX
}

# Cleanup
TMP_FILES=""
cleanup() {
    [ -z "$TMP_FILES" ] || rm -f $TMP_FILES
    unlock_history
}
trap cleanup EXIT

die() { printf '%s\n' "$*" >&2; exit 1; }

# Register a temp file for cleanup
add_tmp() { TMP_FILES="$TMP_FILES $1"; }

show_help() {
    cat <<'EOF'
Usage:
  ai [prompt...]             Ask a question (continues conversation)
  ai -s [prompt...]          Web search (no history)
  ai -i                      Interactive chat mode
  ai -n [prompt...]          Start a new conversation
  ai -p "prompt" [query...]  Override system prompt
  ai --status                Show session info
  echo "..." | ai            Pipe input (no history)
  ai --configure             Configure API key & default model
  -v, --version              Show version info
  -h, --help                 Show this help
EOF
}

# --- History state / helpers defined early so --status can reuse them ---
MESSAGES='[]'
SUMMARY=""
UPDATED_AT=0

load_history() {
    if [ -f "$HISTORY_FILE" ]; then
        MESSAGES=$(jq -c '.messages // []' "$HISTORY_FILE" 2>/dev/null) || MESSAGES='[]'
        SUMMARY=$(jq -r '.summary // "" | gsub("<(think|reasoning)>[\\s\\S]*?</(think|reasoning)>"; "")' "$HISTORY_FILE" 2>/dev/null) || SUMMARY=""
        UPDATED_AT=$(jq -r '.updated_at // 0' "$HISTORY_FILE" 2>/dev/null) || UPDATED_AT=0
    else
        MESSAGES='[]'; SUMMARY=""; UPDATED_AT=0
    fi
    case "$UPDATED_AT" in
        ""|*[!0-9]*) UPDATED_AT=0 ;;
    esac
}

save_history() {
    mkdir -p "$HISTORY_DIR"
    tmp_hist=$(mktemp "$HISTORY_FILE.tmp.XXXXXX") || return
    if ( umask 077; printf '%s' "$MESSAGES" | jq -c \
        --arg summary "$SUMMARY" \
        --argjson ts "$(date +%s)" \
        '{summary: $summary, updated_at: $ts, messages: .}' > "$tmp_hist" ); then
        mv -f "$tmp_hist" "$HISTORY_FILE"
    else
        rm -f "$tmp_hist"
    fi
}

check_expiry() {
    [ "$UPDATED_AT" -eq 0 ] && return
    now=$(date +%s)
    age=$((now - UPDATED_AT))
    [ "$age" -le "$EXPIRY_SECONDS" ] && return
    hrs=$((age / 3600))
    mins=$(( (age % 3600) / 60 ))
    if [ "$hrs" -gt 0 ]; then
        printf '(Session idle %dh %dm. Use -n to start fresh.)\n' "$hrs" "$mins" >&2
    else
        printf '(Session idle %dm. Use -n to start fresh.)\n' "$mins" >&2
    fi
}

run_configure() {
    printf 'Enter your Groq API Key: '
    stty_orig=$(stty -g 2>/dev/null)
    stty -echo 2>/dev/null
    read -r key
    stty $stty_orig 2>/dev/null
    printf '\n'
    [ -n "$key" ] || die "API key cannot be empty."

    printf 'Validating API key and fetching models... '

    hdr_conf=$(mktemp) || die "Failed to create temporary file."
    add_tmp "$hdr_conf"
    ( umask 077; printf 'Authorization: Bearer %s\n' "$key" > "$hdr_conf" )

    resp=$(curl -sS -m 30 -w '\n%{http_code}' \
        -H "Content-Type: application/json" \
        -H @"$hdr_conf" "$API_BASE/models")
    code=${resp##*${nl}}
    body=${resp%${nl}*}
    rm -f "$hdr_conf"

    [ "$code" = "200" ] || {
        echo failed
        err=$(printf '%s' "$body" | jq -r '.error.message // "Unknown error"')
        die "Groq error: $err"
    }
    echo done

    models=$(printf '%s' "$body" | jq -r \
        '.data[].id | select(test("whisper|guard|tts|distil";"i")|not)' | sort)

    if command -v fzf >/dev/null 2>&1; then
        sel=$(printf '%s\n' "$models" | fzf --header='Select default model:')
    else
        echo; echo 'Available chat models:'
        printf '%s\n' "$models" | nl -w2 -s') '
        printf '\nEnter number: '; read -r n
        num_models=$(printf '%s\n' "$models" | wc -l)
        if echo "$n" | grep -qE '^[0-9]+$' && [ "$n" -ge 1 ] && [ "$n" -le "$num_models" ] 2>/dev/null; then  # FIX: grep -qE
            sel=$(printf '%s\n' "$models" | sed -n "${n}p")
        else
            die "Invalid selection: $n"
        fi
    fi
    [ -n "$sel" ] || die "No model selected."

    printf 'Optional default system prompt (Enter to skip): '
    read -r sys

    mkdir -p "$HISTORY_DIR"

    tmp_conf=$(mktemp "$CONFIG_FILE.tmp.XXXXXX") || die "Failed to create temporary config."
    if ( umask 077; jq -n \
        --arg key "$key" --arg mod "$sel" --arg sys "$sys" \
        '{api_key:$key, model:$mod, system_prompt:$sys}' > "$tmp_conf" ); then
        mv -f "$tmp_conf" "$CONFIG_FILE"
    else
        rm -f "$tmp_conf"
        die "Failed to save configuration."
    fi
    echo "Saved to $CONFIG_FILE"
}

# --- Parse options first ---
SEARCH_MODE=0
INTERACTIVE_MODE=0
NEW_SESSION=0
SHOW_STATUS=0
CLI_SYSTEM_PROMPT=""
HAS_CLI_SYSTEM_PROMPT=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        -s|--search) SEARCH_MODE=1; shift ;;
        -i|--interactive) INTERACTIVE_MODE=1; shift ;;
        -n|--new) NEW_SESSION=1; shift ;;
        -p|--system)
            [ "$#" -ge 2 ] || die "Option $1 requires an argument."
            CLI_SYSTEM_PROMPT="$2"; HAS_CLI_SYSTEM_PROMPT=1; shift 2 ;;
        --status) SHOW_STATUS=1; shift ;;
        --configure) run_configure; exit 0 ;;
        -v|--version) echo "ai version 1.0.1"; exit 0 ;;
        -h|--help)   show_help; exit 0 ;;
        --) shift; break ;;
        -*) die "Unknown option: $1" ;;
        *)  break ;;
    esac
done

# --- Load config early ---
API_KEY="${GROQ_API_KEY:-}"
MODEL=""
CONFIG_SYSTEM_PROMPT=""

if [ -f "$CONFIG_FILE" ]; then
    [ -n "$API_KEY" ] || API_KEY=$(jq -r '.api_key // empty' "$CONFIG_FILE")
    MODEL=$(jq -r '.model // empty' "$CONFIG_FILE")
    CONFIG_SYSTEM_PROMPT=$(jq -r '.system_prompt // empty' "$CONFIG_FILE")
fi

[ -n "$MODEL" ] || MODEL="$DEFAULT_MODEL"
[ "$SEARCH_MODE" -eq 1 ] && MODEL="$SEARCH_MODEL"

# --status: local-only operation (FIX: reuse load_history)
if [ "$SHOW_STATUS" -eq 1 ]; then
    if [ ! -f "$HISTORY_FILE" ]; then
        echo "No conversation history."
        exit 0
    fi
    load_history

    msg_count=$(printf '%s' "$MESSAGES" | jq 'length')
    exchanges=$(printf '%s' "$MESSAGES" | jq '[.[] | select(.role == "user")] | length')
    total_chars=$(printf '%s%s' "$SUMMARY" "$(printf '%s' "$MESSAGES" | jq -r '.[].content // ""')" | wc -m)
    est_tokens=$((total_chars / 4))

    if [ "$UPDATED_AT" -eq 0 ]; then
        age_str="unknown"
    else
        now=$(date +%s)
        age=$((now - UPDATED_AT))
        if [ "$age" -lt 60 ]; then
            age_str="${age}s"
        elif [ "$age" -lt 3600 ]; then
            age_str="$((age / 60))m"
        else
            age_str="$((age / 3600))h $((age % 3600 / 60))m"
        fi
    fi

    echo "Model: $MODEL"
    echo "Messages: $msg_count ($exchanges exchanges)"
    echo "Context: ~$est_tokens tokens (est.)"
    echo "Age: $age_str"
    if [ -n "$SUMMARY" ]; then
        printf 'Summary: %s\n' "$(printf '%s' "$SUMMARY" | head -c 200)"
    else
        echo "Summary: None"
    fi
    exit 0
fi

# -n alone: just delete history, no API needed
if [ "$NEW_SESSION" -eq 1 ] && [ "$INTERACTIVE_MODE" -eq 0 ] && [ "$#" -eq 0 ] && [ -t 0 ]; then
    rm -f "$HISTORY_FILE"
    echo "Conversation cleared."
    exit 0
fi

if [ -z "$API_KEY" ]; then
    echo "No Groq configuration found."
    run_configure
    [ -f "$CONFIG_FILE" ] || die "Configuration failed."
    API_KEY=$(jq -r '.api_key // empty' "$CONFIG_FILE")
    MODEL=$(jq -r '.model // empty' "$CONFIG_FILE")
    CONFIG_SYSTEM_PROMPT=$(jq -r '.system_prompt // empty' "$CONFIG_FILE")
fi

[ -n "$API_KEY" ] || die "No API key."
[ -n "$MODEL" ] || MODEL="$DEFAULT_MODEL"

# Resolve system prompt
if [ "$HAS_CLI_SYSTEM_PROMPT" -eq 1 ]; then
    SYSTEM_PROMPT="$CLI_SYSTEM_PROMPT"
else
    SYSTEM_PROMPT="$CONFIG_SYSTEM_PROMPT"
fi

[ "$SEARCH_MODE" -eq 1 ] && MODEL="$SEARCH_MODEL"

# --- Auth header (shared) ---
hdr=$(mktemp) || die "Failed to create temporary file."
add_tmp "$hdr"
( umask 077; printf 'Authorization: Bearer %s\n' "$API_KEY" > "$hdr" )

USE_HISTORY=1
[ ! -t 0 ] && USE_HISTORY=0
[ "$SEARCH_MODE" -eq 1 ] && USE_HISTORY=0

summarize_if_needed() {
    context_size=$(printf '%s%s' "$SUMMARY" "$(printf '%s' "$MESSAGES" | jq -r '.[].content // ""')" | wc -m)
    [ "$context_size" -le "$CONTEXT_THRESHOLD" ] && return

    msg_count=$(printf '%s' "$MESSAGES" | jq 'length')

    if [ "$msg_count" -le "$KEEP_RECENT" ]; then
        summary_size=$(printf '%s' "$SUMMARY" | wc -m)
        if [ "$summary_size" -gt $((CONTEXT_THRESHOLD * 8 / 10)) ]; then
            printf '(Condensing conversation summary...)\n' >&2
            sum_input="Previous summary to condense:\n$SUMMARY"
            keep_msgs="$MESSAGES"
        else
            return
        fi
    else
        printf '(Summarizing older context...)\n' >&2
        old_msgs=$(printf '%s' "$MESSAGES" | jq -c ".[:-$KEEP_RECENT]")
        keep_msgs=$(printf '%s' "$MESSAGES" | jq -c ".[-$KEEP_RECENT:]")
        conv_text=$(printf '%s' "$old_msgs" | jq -r 'map(.role + ": " + .content) | join("\n\n")')

        if [ -n "$SUMMARY" ]; then
            sum_input="Previous summary:\n$SUMMARY\n\nNew conversation to incorporate:\n$conv_text"
        else
            sum_input="$conv_text"
        fi
    fi

    sum_payload=$(jq -cn \
        --arg model "$MODEL" \
        --arg conv "$sum_input" \
        '{model: $model, stream: false,
          messages: [
            {role: "system", content: "Summarize this conversation as extremely concise bullet points. Focus on: key facts, decisions made, code specifics, and pending items. Omit greetings and filler. Condense and merge older points to keep the total summary compact."},
            {role: "user", content: $conv}
          ]}')

    sum_payload_file=$(mktemp) || return
    add_tmp "$sum_payload_file"
    printf '%s' "$sum_payload" > "$sum_payload_file"

    sum_resp=$(curl -sS -m 120 -X POST "$API_BASE/chat/completions" \
        -H "Content-Type: application/json" \
        -H 'Expect:' \
        -H @"$hdr" \
        --data-binary "@$sum_payload_file")

    curl_exit=$?
    rm -f "$sum_payload_file"

    if [ "$curl_exit" -eq 0 ]; then
        # FIX: gsub to strip ALL think/reasoning blocks, not just first
        new_summary=$(printf '%s' "$sum_resp" | jq -r '.choices[0].message.content // "" | gsub("<(think|reasoning)>[\\s\\S]*?</(think|reasoning)>"; "") | sub("^[ \\n\\r\\t]+"; "") | sub("[ \\n\\r\\t]+$"; "")')
        if [ -n "$new_summary" ]; then
            SUMMARY="$new_summary"
            MESSAGES="$keep_msgs"
            printf '(Context summarized. Continuing with recent messages.)\n' >&2
            return
        fi
    fi
    printf '(Summarization failed. Continuing with full context.)\n' >&2
}

# --- --new with prompt or -i: clear history, then continue ---
[ "$NEW_SESSION" -eq 1 ] && rm -f "$HISTORY_FILE"

send_query() {
    query="$1"

    if [ "$USE_HISTORY" -eq 1 ]; then
        lock_history
        load_history
        MESSAGES=$(printf '%s' "$MESSAGES" | jq -c --arg c "$query" '. + [{role:"user",content:$c}]')
        summarize_if_needed
    fi

    if [ "$USE_HISTORY" -eq 1 ]; then
        combined_sys=""
        [ -n "$SYSTEM_PROMPT" ] && combined_sys="$SYSTEM_PROMPT"
        if [ -n "$SUMMARY" ]; then
            if [ -n "$combined_sys" ]; then
                combined_sys="${combined_sys}${nl}${nl}Previous conversation context:${nl}${SUMMARY}"
            else
                combined_sys="Previous conversation context:${nl}${SUMMARY}"
            fi
        fi

        JSON_PAYLOAD=$(jq -cn \
            --arg model "$MODEL" \
            --arg sys "$combined_sys" \
            --argjson msgs "$MESSAGES" \
            '{model: $model, stream: true,
              messages: (
                (if $sys != "" then [{role:"system",content:$sys}] else [] end) +
                $msgs
              )}')
    else
        JSON_PAYLOAD=$(jq -cn \
            --arg model "$MODEL" \
            --arg sys "$SYSTEM_PROMPT" \
            --arg msg "$query" \
            '{model:$model, stream:true,
              messages:(if $sys != "" then
                [{role:"system",content:$sys},{role:"user",content:$msg}]
              else
                [{role:"user",content:$msg}]
              end)}')
    fi

    payload_file=$(mktemp) || die "Failed to create temporary payload file."
    add_tmp "$payload_file"
    printf '%s' "$JSON_PAYLOAD" > "$payload_file"

    headers_file=$(mktemp) || die "Failed to create temporary headers file."
    exit_code_file=$(mktemp) || die "Failed to create temporary exit code file."
    add_tmp "$headers_file"; add_tmp "$exit_code_file"

    response_file=""
    if [ "$USE_HISTORY" -eq 1 ]; then
        response_file=$(mktemp) || die "Failed to create temporary response file."
        add_tmp "$response_file"
    fi

    (
        (
            curl -sS -N -m 600 -X POST "$API_BASE/chat/completions" \
                -D "$headers_file" \
                -H "Content-Type: application/json" \
                -H 'Expect:' \
                -H @"$hdr" \
                --data-binary "@$payload_file"
            echo $? > "$exit_code_file"
        ) | {
            first_line=""
            while read -r line; do
                if [ -n "$line" ]; then
                    first_line="$line"
                    break
                fi
            done

            [ -z "$first_line" ] && exit 0

            case "$first_line" in
                data:*)
                    ( printf '%s\n' "$first_line"; cat ) \
                    | sed -nu '/^data: \[DONE\]/d; s/^data: //; p' \
                    | jq -n -j --unbuffered 'foreach inputs as $line ({thinking: false, started: false, buf: "", out: "", stop: false}; (( $line.choices[0].delta.content // $line.error.message // "" ) as $c | .buf += $c | .out = "" | .stop = false | until(.stop; if .thinking then if (.buf | contains("</think>")) then (.buf | index("</think>")) as $idx | .thinking = false | .buf = .buf[$idx + 8:] elif (.buf | contains("</reasoning>")) then (.buf | index("</reasoning>")) as $idx | .thinking = false | .buf = .buf[$idx + 12:] else .stop = true end else if (.buf | contains("<think>")) then (.buf | index("<think>")) as $idx | .thinking = true | .buf = .buf[$idx + 7:] elif (.buf | contains("<reasoning>")) then (.buf | index("<reasoning>")) as $idx | .thinking = true | .buf = .buf[$idx + 11:] else if (.buf | contains("<")) then (.buf | index("<")) as $idx | if $idx > 0 then .out += .buf[:$idx] | .buf = .buf[$idx:] elif (.buf | length > 12) then .out += "<" | .buf = .buf[1:] else .stop = true end else .out += .buf | .buf = "" | .stop = true end end end) | if .out != "" and (.started | not) then ((.out | sub("^[ \\n\\r\\t]+"; "")) as $s | if $s != "" then .started = true | .out = $s else .out = "" end) else . end); .out)'
                    ;;
                *)
                    full_body=$(printf '%s\n' "$first_line"; cat)
                    err_msg=$(printf '%s' "$full_body" | jq -r '.error.message // .message // "Unknown error"')
                    printf 'Error: %s\n' "$err_msg" >&2
                    echo "99" > "$exit_code_file"
                    ;;
            esac
        }
    ) | {
        if [ "$USE_HISTORY" -eq 1 ]; then
            tee "$response_file"
        else
            cat
        fi
    }

    curl_exit_code=$(cat "$exit_code_file" 2>/dev/null)
    [ -n "$curl_exit_code" ] || curl_exit_code=0

    # FIX: take the LAST HTTP status line (handles 100 Continue / redirects)
    http_status=""
    if [ -f "$headers_file" ]; then
        http_status=$(awk 'toupper($1) ~ /^HTTP/ {s=$2} END{print s}' "$headers_file")
    fi

    rm -f "$payload_file" "$headers_file" "$exit_code_file"

    if [ "$curl_exit_code" -ne 0 ] || { [ -n "$http_status" ] && [ "$http_status" -ne 200 ]; }; then
        printf '\n'
        if [ "$USE_HISTORY" -eq 1 ]; then
            rm -f "$response_file"
            unlock_history
        fi
        return 1
    fi

    printf '\n'

    if [ "$USE_HISTORY" -eq 1 ]; then
        response=$(cat "$response_file")
        if [ -n "$response" ]; then
            MESSAGES=$(printf '%s' "$MESSAGES" | jq -c --arg c "$response" '. + [{role:"assistant",content:$c}]')
            save_history
        fi
        rm -f "$response_file"
        unlock_history
    fi
}

# --- Interactive mode ---
if [ "$INTERACTIVE_MODE" -eq 1 ]; then
    [ -t 0 ] || die "Interactive mode requires a terminal."

    if [ "$USE_HISTORY" -eq 1 ]; then
        load_history
        check_expiry
    fi

    while printf 'ai> ' && IFS= read -r line; do
        [ -z "$line" ] && continue
        case "$line" in exit|quit|bye) break ;; esac
        send_query "$line"
    done
    exit 0
fi

# --- One-shot mode ---
PROMPT="$*"
if [ ! -t 0 ]; then
    stdin_data=$(cat)
    if [ -n "$PROMPT" ]; then
        PROMPT="${stdin_data}${nl}${PROMPT}"
    else
        PROMPT="$stdin_data"
    fi
fi
[ -n "$PROMPT" ] || { show_help; exit 0; }

if [ "$USE_HISTORY" -eq 1 ]; then
    load_history
    check_expiry
fi

send_query "$PROMPT"