#!/bin/bash
set -euo pipefail

CONFIG_DIR="$HOME/.config/aikular"
CONFIG_FILE="$CONFIG_DIR/backend"

error_exit() {
    echo "Error: $1" >&2
    exit 1
}

notify() {
    local title="$1" message="$2"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -a "Aikular" "$title" "$message" || true
    else
        echo "[$title] $message" >&2
    fi
}

get_backend() {
    if [[ -f "$CONFIG_FILE" ]]; then
        local val
        val=$(tr -d '[:space:]' < "$CONFIG_FILE" || echo "agy")
        if [[ "$val" == "opencode" || "$val" == "agy" ]]; then
            echo "$val"; return
        fi
    fi
    echo "agy"
}

for tool in python3 realpath md5sum cut dirname basename setsid sqlite3 flock find; do
    command -v "$tool" >/dev/null 2>&1 || error_exit "Required system tool '$tool' is not installed."
done

REFRESH=false
IMAGES_MODE="auto"   # auto | all | none

# Parse leading options; early-exit subcommands handled inline.
while [[ $# -gt 0 ]]; do
    case "$1" in
        --refresh)   REFRESH=true; shift ;;
        --images)    IMAGES_MODE="all"; shift ;;
        --no-images) IMAGES_MODE="none"; shift ;;
        --clean)
            shift
            CLEAN_SCRIPT="${BASH_SOURCE[0]%/*}/aikular-clean"
            [[ ! -f "$CLEAN_SCRIPT" ]] && CLEAN_SCRIPT="$HOME/.local/bin/aikular-clean"
            [[ -f "$CLEAN_SCRIPT" ]] && exec "$CLEAN_SCRIPT" "$@"
            error_exit "Cleanup script not found."
            ;;
        --switch)
            CURRENT=$(get_backend)
            [[ "$CURRENT" == "agy" ]] && NEW="opencode" || NEW="agy"
            mkdir -p "$CONFIG_DIR"
            echo "$NEW" > "$CONFIG_FILE"
            echo "Aikular backend switched: $CURRENT -> $NEW"
            exit 0
            ;;
        --backend)
            echo "Current backend: $(get_backend)"
            exit 0
            ;;
        --) shift; break ;;
        -*) error_exit "Unknown option: $1" ;;
        *)  break ;;
    esac
done

PDF_PATH="${1:-}"
if [[ -z "$PDF_PATH" ]]; then
    cat >&2 <<EOF
Usage: aikular [options] <pdf_path>

Options:
  --refresh     Force re-parse (clear cache first)
  --images      Render EVERY page to PNG (default: only visual pages)
  --no-images   Skip all page rendering (text only)
  --clean       Clean cache for a PDF or directory
  --switch      Toggle backend between agy and opencode
  --backend     Show current backend

Note: page renders let the AI read figures/charts/scans directly.
Changing --images/--no-images on a cached PDF needs --refresh to take effect.
EOF
    exit 1
fi

ABS_PDF_PATH=$(realpath "$PDF_PATH")
PDF_DIR=$(dirname "$ABS_PDF_PATH")
PDF_NAME=$(basename "$ABS_PDF_PATH")
PDF_STEM="${PDF_NAME%.*}"

if [[ ! -f "$ABS_PDF_PATH" || "${PDF_NAME,,}" != *.pdf ]]; then
    error_exit "File '$PDF_PATH' does not exist or is not a PDF."
fi

if [[ -w "$PDF_DIR" ]]; then
    OUTPUT_DIR="$PDF_DIR/.aikular/$PDF_STEM"
else
    DIR_HASH=$(echo -n "$PDF_DIR" | md5sum | cut -d' ' -f1 | cut -c1-8)
    OUTPUT_DIR="/tmp/aikular-${USER}/${PDF_STEM}-${DIR_HASH}"
fi

OUTLINE_PATH="$OUTPUT_DIR/outline.md"
CONTEXT_PATH="$OUTPUT_DIR/context.md"

PARSER_SCRIPT="${BASH_SOURCE[0]%/*}/aikular_parser.py"
[[ ! -f "$PARSER_SCRIPT" ]] && PARSER_SCRIPT="$HOME/.local/bin/aikular_parser.py"
[[ ! -f "$PARSER_SCRIPT" ]] && error_exit "Parser script not found at '$PARSER_SCRIPT'"

RENDER_TOOL="${BASH_SOURCE[0]%/*}/aikular-render"
[[ ! -x "$RENDER_TOOL" ]] && RENDER_TOOL="$HOME/.local/bin/aikular-render"

# Serialise parsing of the same PDF; lock lives beside the cache dir.
mkdir -p "$(dirname "$OUTPUT_DIR")"
LOCK_FILE="${OUTPUT_DIR}.lock"
exec 9>"$LOCK_FILE"
flock -w 120 9 || error_exit "Timed out waiting for another aikular parse to finish."

[[ "$REFRESH" == true ]] && rm -rf "$OUTPUT_DIR"

if [[ ! -f "$CONTEXT_PATH" ]]; then
    notify "Parsing PDF..." "$PDF_NAME"
    if ! python3 "$PARSER_SCRIPT" "$ABS_PDF_PATH" "$OUTPUT_DIR" --images "$IMAGES_MODE"; then
        rm -rf "$OUTPUT_DIR"
        error_exit "PDF parsing failed. Cleaned up corrupt cache."
    fi
fi

flock -u 9   # release lock before launching interactive UI

BACKEND=$(get_backend)

for tool in okular ghostty fish "$BACKEND"; do
    command -v "$tool" >/dev/null 2>&1 || error_exit "Required application '$tool' is not installed or not in PATH."
done

setsid okular "$ABS_PDF_PATH" >/dev/null 2>&1 &

SEED_PROMPT="You are analysing the PDF: $PDF_NAME (path: $ABS_PDF_PATH).
Document map: $OUTLINE_PATH. Read this FIRST.
Full text: $CONTEXT_PATH (pages separated by <!-- page: N --> markers).

Pages tagged 'visual' or 'has_figure' already have a rendered PNG referenced by absolute path in context.md; read it with your image tool. The per-page 'chars/raster/draw' counts are only a heuristic hint and can be wrong.

To see ANY page as an image (including pages the parser did not pre-render, or when text looks garbled or incomplete, or to inspect a diagram, table or scan), run this and read the PNG path(s) it prints:
  $RENDER_TOOL \"$ABS_PDF_PATH\" <pages>
Examples: $RENDER_TOOL \"$ABS_PDF_PATH\" 12   (or 12,14  or 12-15  or all)
Zoom into a region: add --bbox x0,y0,x1,y1 (PDF points), optionally --dpi 220.

Never claim a page is empty or unreadable before rendering it and looking.
The PDF is also open in Okular for the human's reference.
Always cite [Page N] when answering."

notify "Ready" "Okular + $BACKEND session started"
export SEED_PROMPT

SESSION_ID_FILE="$OUTPUT_DIR/${BACKEND}_session_id"

# Best-effort session capture. NOTE: ghostty -e may return before the backend
# writes its session row, so this can miss the very first session. Persistence
# is reliable on the second launch onward. A backend flag that prints its own
# session id would remove the race entirely.
newest_file() {  # newest_file <dir> <glob>
    find "$1" -maxdepth 1 -name "$2" -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -n1 | cut -d' ' -f2-
}

if [[ "$BACKEND" == "opencode" ]]; then
    if [[ -s "$SESSION_ID_FILE" ]]; then
        SAVED_ID=$(cat "$SESSION_ID_FILE")
        ghostty --title="aikular: $PDF_STEM" --working-directory="$PDF_DIR" -e fish -c "opencode --session \"$SAVED_ID\""
    else
        ghostty --title="aikular: $PDF_STEM" --working-directory="$PDF_DIR" -e fish -c "opencode --prompt \"\$SEED_PROMPT\""
        NEW_ID=$(sqlite3 "$HOME/.local/share/opencode/opencode.db" \
                 "SELECT id FROM session ORDER BY time_created DESC LIMIT 1;" 2>/dev/null || true)
        [[ -n "$NEW_ID" ]] && echo "$NEW_ID" > "$SESSION_ID_FILE"
    fi
else
    if [[ -s "$SESSION_ID_FILE" ]]; then
        SAVED_ID=$(cat "$SESSION_ID_FILE")
        ghostty --title="aikular: $PDF_STEM" --working-directory="$PDF_DIR" -e fish -c "agy --dangerously-skip-permissions --conversation \"$SAVED_ID\""
    else
        ghostty --title="aikular: $PDF_STEM" --working-directory="$PDF_DIR" -e fish -c 'agy --dangerously-skip-permissions -i "$SEED_PROMPT"'
        NEW_DB=$(newest_file "$HOME/.gemini/antigravity-cli/conversations" "*.db")
        if [[ -n "$NEW_DB" ]]; then
            NEW_ID=$(basename "$NEW_DB" .db)
            echo "$NEW_ID" > "$SESSION_ID_FILE"
        fi
    fi
fi
